# LLM provider (OpenAI-compatible API)
# For local Ollama: use base_url below and any placeholder for the key.
OPENAI_API_KEY=placeholder
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b

# Generation
TEMPERATURE=0.7
MAX_TOKENS=1024

# Optional: set to run integration tests against a real LLM
# OLLAMA_URL=http://localhost:11434/v1
